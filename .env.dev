# ============================================================================
# DOCKER-COMPOSE DEV ENVIRONMENT VARIABLES
#
# Plik konfiguracyjny dla testowej wersji docker-compose.dev.yml
# ============================================================================

# Application Configuration
ENVIRONMENT=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Controller Service
CONTROLLER_PORT=8000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=devpassword

# Network Configuration
COMPOSE_NETWORK=crypto_network

# Development Settings
DEBUG=true
VERBOSE_LOGGING=true

# Health Check Settings (in seconds)
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Resource Limits (for local development)
CPU_LIMIT_PYTHON=0.5
MEMORY_LIMIT_PYTHON=512M
CPU_LIMIT_CPP=0.5
MEMORY_LIMIT_CPP=256M

# Paths
LOGS_PATH=/app/logs
CACHE_PATH=/app/cache

# Optional: Database Configuration (for future expansion)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=crypto_analysis
# DB_USER=developer
# DB_PASSWORD=devpassword
